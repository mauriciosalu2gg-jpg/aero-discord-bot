# Copia este archivo como .env y completa los valores
# En Render, pon estas variables en Environment Variables

DISCORD_TOKEN=

GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
LM_STUDIO_URL=http://localhost:1234

# --- Permisos ---
# ID de Discord de Lara (recomendado). Sirve como owner del bot aunque
# cambie de username. Click derecho en Discord (modo desarrollador activado) -> Copiar ID.
OWNER_DISCORD_ID=
# IDs de otros admins, separados por coma (opcional)
ADMIN_DISCORD_IDS=

# --- Busqueda web opcional ---
# Si la dejas vacia, el bot simplemente no busca en la web y responde
# solo con lo que ya sabe.
TAVILY_API_KEY=

DEBUG=false
