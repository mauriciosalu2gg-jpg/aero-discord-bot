# Copia este archivo como .env y completa los valores
# En Render, pon estas variables en Environment Variables

DISCORD_TOKEN=
# Application ID del bot (Discord Developer Portal > General Information).
# Necesario para deploy-commands.js (registro de slash commands).
DISCORD_CLIENT_ID=

# --------------------------------------------------
# API Keys de IA — cada proveedor es independiente.
# Rotar o cambiar una key es solo editar esta linea,
# no hace falta tocar codigo.
# Orden de prioridad configurable en secrets.js -> PROVIDER_PRIORITY
# --------------------------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# Opcional: atribución para OpenRouter (no afecta la lógica)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# --------------------------------------------------
# Memory Engine (Fondo de Memoria e IA)
# REGLA DE AISLAMIENTO: Las llaves de chat definidas arriba NO deben usarse aquí.
# El Memory Engine requiere sus propias llaves dedicadas y exclusivas para evitar 
# interferir y agotar los rate limits del chat principal.
# --------------------------------------------------
MEMORY_ENABLED=true
MEMORY_PROVIDER=router
MEMORY_GROQ_KEY_1=
MEMORY_GROQ_KEY_2=
MEMORY_GEMINI_KEY=
MEMORY_OLLAMA_URL=http://localhost:11434
MEMORY_TOPIC_MODEL=llama-3.1-8b
MEMORY_SUMMARY_MODEL=llama-3.3-70b
MEMORY_PROFILE_MODEL=gemma-3

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
LM_STUDIO_URL=http://localhost:1234

# --- Permisos ---
# Lara: creadora principal / owner del bot.
OWNER_DISCORD_ID=971639277626720268
# Gio: sub-creador, le dio imagen/descripcion/apariencia al bot ("little gio").
SUB_CREATOR_DISCORD_ID=1005707582389899305
ADMIN_DISCORD_IDS=

# --- Busqueda web opcional ---
TAVILY_API_KEY=

DEBUG=false
